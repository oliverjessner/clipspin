{
    "name": "clipspin",
    "version": "0.1.3",
    "description": "A temporary macOS clipboard cycler CLI that iterates through JSON text snippets on every Cmd+V.",
    "type": "module",
    "bin": {
        "clipspin": "index.js"
    },
    "files": [
        "index.js",
        "README.md"
    ],
    "scripts": {
        "start": "node index.js",
        "dev": "node index.js",
        "lint": "node --check index.js",
        "prepublishOnly": "npm run lint",
        "publish:npm": "npm publish --access public",
        "publish:brew": "node scripts/update-homebrew-formula.js",
        "publish": "npm login && npm run publish:npm && npm run publish:brew"
    },
    "keywords": [
        "clipboard",
        "paste",
        "macos",
        "cli",
        "snippet",
        "cmd-v",
        "productivity"
    ],
    "author": "Oliver Jessner",
    "license": "MIT",
    "engines": {
        "node": ">=20"
    },
    "os": [
        "darwin"
    ],
    "dependencies": {
        "uiohook-napi": "^1.5.5"
    }
}
